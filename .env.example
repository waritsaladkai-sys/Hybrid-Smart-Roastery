# ══════════════════════════════════════════════════════════
# Eight Coffee Roasters — Cloud Environment Variables
# Supabase + Vercel Edition
# ══════════════════════════════════════════════════════════

# ── Supabase (จาก Project Settings > API) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://eatlvoysvkfzooksbya.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...paste_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJ...paste_service_role_key_here

# ── Google Gemini AI ───────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── GB Prime Pay ────────────────────────────────────────────
# 'mock' → ใช้ simulate mode (Dev)
# key จริง → ไปที่ gbprimepay.com
PAYMENT_PROVIDER=mock
GBPAY_PUBLIC_KEY=mock
GBPAY_TOKEN=mock

# ── Flash Express ───────────────────────────────────────────
FLASH_API_KEY=your_flash_api_key
FLASH_API_URL=https://api.flashexpress.co.th

# ── LINE OA ─────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_token
NEXT_PUBLIC_LIFF_ID=your_liff_id

# ── IoT (ESP32 / Load Cell) ─────────────────────────────────
IOT_API_KEY=CHANGE_ME_random_secret_for_iot_devices
LOW_STOCK_KG=5

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
