# ══════════════════════════════════════════
# Eight Coffee Roasters — Environment Config
# Copy: cp .env.example .env  then fill in values
# ══════════════════════════════════════════

# ── Database ───────────────────────────────
POSTGRES_USER=eight_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=eight_coffee
DATABASE_URL=postgresql://eight_admin:CHANGE_ME_strong_password@localhost:5432/eight_coffee

# ── Redis ──────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379

# ── JWT ────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_32_char_secret_here
JWT_EXPIRES_IN=7d

# ── LINE OA / LIFF ─────────────────────────
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_access_token
LINE_ADMIN_GROUP_ID=your_admin_line_group_id
NEXT_PUBLIC_LIFF_ID=your_liff_id

# ── Google Gemini AI ───────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── GB Prime Pay (mock for dev) ─────────────
GBPAY_PUBLIC_KEY=mock
GBPAY_TOKEN=mock
GBPAY_MERCHANT_ID=

# ── Flash Express ───────────────────────────
FLASH_API_KEY=your_flash_api_key
FLASH_API_URL=https://api.flashexpress.co.th
FLASH_SENDER_NAME=Eight Coffee Roasters
FLASH_SENDER_PHONE=0800000000
FLASH_SENDER_POSTCODE=10110

# ── Next.js ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret

# ── Cloudflare Tunnel ───────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ── Synology NAS (SMB mount on RPi) ────────
NAS_MEDIA_PATH=/mnt/nas/media
NAS_BACKUP_PATH=/mnt/nas/backup

# ── App ─────────────────────────────────────
NODE_ENV=development
PORT=4000
